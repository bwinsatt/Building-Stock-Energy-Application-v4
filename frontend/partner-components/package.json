{
  "name": "@partnerdevops/partner-components",
  "version": "0.0.27",
  "description": "Vue component library for Partner applications",
  "type": "module",
  "main": "./dist/p-components.umd.js",
  "module": "./dist/p-components.es.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": "^24 || ^22 || ^20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/p-components.es.js",
      "require": "./dist/p-components.umd.js"
    },
    "./agent-artifacts/exports/component-catalog.json": "./agent-artifacts/exports/component-catalog.json",
    "./agent-artifacts/exports/component-examples.json": "./agent-artifacts/exports/component-examples.json",
    "./agent-artifacts/exports/design-tokens.json": "./agent-artifacts/exports/design-tokens.json",
    "./agent-artifacts/exports/figma-component-map.json": "./agent-artifacts/exports/figma-component-map.json",
    "./agent-artifacts/exports/figma-mapping-hints.json": "./agent-artifacts/exports/figma-mapping-hints.json",
    "./agent-artifacts/exports/ai-artifacts.md": "./agent-artifacts/exports/ai-artifacts.md",
    "./agent-artifacts/schemas/component-catalog.schema.json": "./agent-artifacts/schemas/component-catalog.schema.json",
    "./agent-artifacts/schemas/component-examples.schema.json": "./agent-artifacts/schemas/component-examples.schema.json",
    "./agent-artifacts/schemas/design-tokens.schema.json": "./agent-artifacts/schemas/design-tokens.schema.json",
    "./agent-artifacts/schemas/figma-component-map.schema.json": "./agent-artifacts/schemas/figma-component-map.schema.json",
    "./agent-artifacts/schemas/figma-mapping-hints.schema.json": "./agent-artifacts/schemas/figma-mapping-hints.schema.json",
    "./dist/style.css": "./dist/partner-components.css",
    "./dist/partner-components.css": "./dist/partner-components.css"
  },
  "files": [
    "dist",
    "agent-artifacts/exports/component-catalog.json",
    "agent-artifacts/exports/component-examples.json",
    "agent-artifacts/exports/design-tokens.json",
    "agent-artifacts/exports/figma-component-map.json",
    "agent-artifacts/exports/figma-mapping-hints.json",
    "agent-artifacts/exports/ai-artifacts.md",
    "agent-artifacts/exports/README.md",
    "agent-artifacts/schemas"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PartnerDevOps/partner-components.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "npm run agent-artifacts:prepare && npm run build:lib",
    "build:lib": "vite build",
    "type-check": "vue-tsc --noEmit",
    "add-component": "npx shadcn-vue@latest add",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-pattern 'node_modules' --ignore-pattern 'dist'",
    "lint:fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-pattern 'node_modules' --ignore-pattern 'dist'",
    "test": "npm run test:node && vitest",
    "test:node": "vitest run --config vitest.node.config.ts",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "agent-artifacts:sync": "node scripts/sync-agent-artifacts.mjs",
    "agent-artifacts:prepare": "npm run agent-artifacts:sync && npm run agent-artifacts:validate",
    "agent-artifacts:generate": "node scripts/generate-agent-artifacts.mjs",
    "agent-artifacts:validate": "node scripts/validate-agent-artifacts.mjs",
    "agent-artifacts:update": "npm run agent-artifacts:generate && npm run agent-artifacts:prepare",
    "icons:update": "node scripts/update-carbon-icons.cjs",
    "icons:clean": "node scripts/clean-svg-colors.cjs",
    "icons:clean-outline": "node scripts/clean-svg-colors.cjs src/assets/icons/outline",
    "icons:clean-solid": "node scripts/clean-svg-colors.cjs src/assets/icons/solid",
    "version:set": "node scripts/set-version.cjs",
    "publish": "npm publish",
    "prepack": "npm run agent-artifacts:generate && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "luxon": "^3.7.2",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "vue-sonner": "^2.0.9"
  },
  "author": "Partner Engineering & Science, Inc",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-links": "^10.1.8",
    "@storybook/addon-themes": "^10.1.8",
    "@storybook/vue3-vite": "^10.1.8",
    "@tailwindcss/vite": "^4.1.11",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/browser-playwright": "^4.0.17",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.32.0",
    "eslint-plugin-storybook": "10.1.8",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "playwright": "^1.57.0",
    "storybook": "^10.1.8",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "vite": "^6.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17",
    "vitest-browser-vue": "^2.0.1",
    "vue-router": "^4.5.1",
    "vue-tsc": "^3.2.1"
  }
}

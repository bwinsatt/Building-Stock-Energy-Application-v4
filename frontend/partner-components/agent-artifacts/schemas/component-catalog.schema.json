{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://partnerdevops/schemas/component-catalog.schema.json",
  "title": "Partner Components Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "components"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "import",
        "status",
        "source",
        "stories",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^p-[a-z0-9-]+$"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["stable", "beta", "deprecated", "internal"]
        },
        "purpose": {
          "type": "string"
        },
        "import": {
          "$ref": "#/$defs/importRef"
        },
        "source": {
          "$ref": "#/$defs/sourceRef"
        },
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/prop"
          },
          "default": []
        },
        "slots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slot"
          },
          "default": []
        },
        "emits": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/emit"
          },
          "default": []
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/variant"
          },
          "default": []
        },
        "layoutConstraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "accessibilityNotes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "useWhen": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "avoidWhen": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "compositionWith": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "stories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/storyRef"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fileRef"
          },
          "default": []
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "importRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["package", "named"],
      "properties": {
        "package": {
          "type": "string"
        },
        "named": {
          "type": "string"
        }
      }
    },
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string"
        }
      }
    },
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file"],
      "properties": {
        "file": {
          "type": "string"
        }
      }
    },
    "storyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "file"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "file": {
          "type": "string"
        }
      }
    },
    "prop": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "description": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "emit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "payload": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}

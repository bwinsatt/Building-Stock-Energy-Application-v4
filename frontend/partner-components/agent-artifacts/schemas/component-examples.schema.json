{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://partnerdevops/schemas/component-examples.schema.json",
  "title": "Partner Component Examples",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "examples"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "examples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/example"
      }
    }
  },
  "$defs": {
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "storyId",
        "storyName",
        "componentName",
        "sourceFile",
        "args",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "storyId": {
          "type": "string"
        },
        "storyName": {
          "type": "string"
        },
        "componentName": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        },
        "args": {
          "type": "object"
        },
        "codeSnippet": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://partnerdevops/schemas/figma-mapping-hints.schema.json",
  "title": "Partner Figma Mapping Hints",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "mappings"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "mappings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mapping"
      }
    }
  },
  "$defs": {
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "mapsTo", "confidence"],
      "properties": {
        "pattern": {
          "type": "string"
        },
        "mapsTo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["component"],
          "properties": {
            "component": {
              "type": "string"
            },
            "variant": {
              "type": "string"
            },
            "props": {
              "type": "object"
            },
            "composition": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "notes": {
          "type": "string"
        },
        "ambiguityRules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "fallbackRules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
